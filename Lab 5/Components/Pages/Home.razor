@page "/"

<PageTitle>Home</PageTitle>

<div class="hero-card">
    <p class="hero-eyebrow">Lab 6 Project</p>
    <h1>Library Management System</h1>
    <p class="hero-text">
        A Blazor web application for managing books, users, and borrowing activity
        through a simple, organized interface.
    </p>
</div>

<div class="card-grid">
    <div class="card">
        <h3>Manage Books</h3>
        <p>Create, update, review, and remove books from the catalog.</p>
        <a class="button-link" href="/books">Open Books</a>
    </div>

    <div class="card">
        <h3>Manage Users</h3>
        <p>Maintain user records and keep contact details organized.</p>
        <a class="button-link" href="/users">Open Users</a>
    </div>

    <div class="card">
        <h3>Borrow & Return</h3>
        <p>Track active loans, process returns, and review borrowed books by user.</p>
        <a class="button-link" href="/borrow-return">Open Borrow / Return</a>
    </div>
</div>
